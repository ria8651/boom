# Copy this file to .env and fill in the values before running the app.

# LiveKit credentials. Arbitrary strings but should be randomly generated for
# production. You can create API keys with `npm run generate-keys` in the
# root of this repo, or via the LiveKit dashboard if using a hosted deployment.
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Address LiveKit advertises to browsers as the WebRTC media endpoint.
# Required: must be a routable IP — the container's loopback (127.0.0.1) is
# unreachable from the browser. Set to your LAN IP for local dev (find via
# `ifconfig | grep "inet 192"`) or your public IP in production. compose
# refuses to start if this is unset.
LIVEKIT_NODE_IP=

# URL the browser uses to reach LiveKit. For a full-stack local compose
# deployment on the same machine, ws://localhost:7880 (the default in
# compose.yaml) works. Override for remote/production.
# LIVEKIT_URL=wss://livekit.example.com

# Optional: URL boom uses to reach LiveKit internally. In most cases this 
# can be left unset as it will fall back to LIVEKIT_URL. Useful for having
# the client and boom use different URLs to reach LiveKit. For *boom* in
# compose this is hardcoded to ws://livekit:7880.
# LIVEKIT_SERVER_URL=

# Access control — at least one must be set (fail closed if both empty)
BOOM_ALLOWED_USERS=alice,bob
BOOM_ALLOWED_ORGS=my-org

# Random string for signing session cookies. Rotating this also acts as a
# force-logout: every outstanding session and invite token stops verifying.
BOOM_SESSION_SECRET=change-me-to-a-random-string

# Host directory for recording output. Mounted into both the egress and boom
# containers at /out; boom reads from here to list/stream/delete recordings.
# Defaults to ./recordings in the current directory.
# BOOM_RECORDINGS_DIR=/path/to/recordings

# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
